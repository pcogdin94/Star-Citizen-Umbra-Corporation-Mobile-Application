<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UmbraCorpApp.MainPage">
    <ScrollView>
        <VerticalStackLayout Margin="0" BackgroundColor="Black">
        
            <Label Text="Umbra Corp" 
                Padding="20"
                HorizontalTextAlignment="Center" 
                FontFamily="VikingSquad" 
                FontSize="60"
                TextColor="#962323"/>

            <Image Source="ucorlogo.png" 
                     HeightRequest="356"
                     WidthRequest="356"
                     HorizontalOptions="Center"
                     />

            <Label Text="Victoria ex Umbra&#10;&#10;Umbra Corporation is a private interstellar enterprise built around logistics, security, intelligence, racing, and strategic influence."
                Padding="20"
                HorizontalTextAlignment="Center"
                FontFamily="VikingSquad"
                FontSize="25"
                TextColor="#962323"
                />

            <WebView
                x:Name="HomeVideoWebView"
                HeightRequest="400" />

        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>
