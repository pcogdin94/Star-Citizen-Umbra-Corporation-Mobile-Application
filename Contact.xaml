<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UmbraCorpApp.Contact"
             Title="Contact">
    
    <VerticalStackLayout BackgroundColor="Black">

        <Label 
            Padding="20"
            Text="Contact the Developer"
            VerticalTextAlignment="Center"
            HorizontalTextAlignment="Center"
            TextColor="#962323"
            FontFamily="VikingSquad"
            FontSize="45"
            />
        
        <!-- User E-mail Display -->
        <Label
            x:Name="UserEmailLabel"
            TextColor="#962323"
            FontSize="25"
            VerticalTextAlignment="Center"
            HorizontalTextAlignment="Center"/>

        <!-- Message -->
        <Editor
            x:Name="MessageBody"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            HeightRequest="250"
            WidthRequest="250"
            BackgroundColor="White"
            Placeholder="Your Message"
            Margin="0,10,0,5"
            />
        
        <!-- Purpose -->

        <Picker
            x:Name="Purpose"
            Title="What is this concerning?"
            SelectedIndexChanged="Purpose_SelectedIndexChanged"
            BackgroundColor="White"
            HeightRequest="30"
            WidthRequest="250">

            <Picker.Items>
                <x:String>Bug Report</x:String>
                <x:String>Suggestion</x:String>
                <x:String>Other</x:String>
            </Picker.Items>

        </Picker>

        <Button
            Text="Send"
            Margin="0, 5, 0, 5"
            WidthRequest="100"
            HeightRequest="40"
            Clicked="OnSendClicked"
            />

    </VerticalStackLayout>
    
</ContentPage>